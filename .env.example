# Path — environment variables
# Copy this file to .env and fill in your values before running docker compose.

# SilverBullet login credentials.
# Format: username:password
# Choose something strong — this is the only thing standing between
# your portfolio and the open internet if you ever expose the port.
SB_USER=admin:changeme

# Host interface SilverBullet binds to. Defaults to 127.0.0.1 (loopback only),
# so the app is reachable only from this machine. Set to 0.0.0.0 to expose it
# on your LAN / for remote access — only do this with a strong SB_USER above.
SB_BIND_HOST=127.0.0.1
