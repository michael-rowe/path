# =============================================================
# Path — .gitignore
#
# Personal content stays on your machine. System files (plug,
# templates, config, docker setup) are what gets committed.
# =============================================================

# --- Personal portfolio content (never commit user data) ---
space/claims/
space/cpd/
space/reflections/
space/captures/
space/network/
space/credentials/
space/personal-statements/
space/evidence/
space/evidence-inventory/
space/Inbox/
space/milestones/

# Path scaffold files are installed at runtime via Path: Add framework.
# Only the browse index ships with the repo.
space/paths/*.md
!space/paths/index.md

# _system/ files are user state created at runtime — only the .gitkeep ships
space/_system/*.md

# Local-only framework definitions (e.g. private job-application person specs).
# criteria/ and standards/ otherwise ship the public frameworks, so these are
# excluded by name rather than by directory. rcs-* = Royal College of Surgeons
# DoE application — confidential, must never reach the public repo.
space/criteria/rcs-*.md
space/standards/rcs-*.yaml

# Personal/transient build drivers for private job-application frameworks.
# Both hardcode confidential person specs and application evidence (RCS DoE,
# ForPsy AP — citation counts, grant figures, supervision record) and must
# never reach the public repo.
path-mcp/build_forpsy_demo.py
path-mcp/framework_builder.py

# --- Secrets and auth ---
space/.silverbullet.auth.json
.env

# --- Generated output ---
exports/

# --- Build artefacts ---
path-plug/node_modules/
path-plug/*.js.map
__pycache__/

# --- Nested repo ---
# path-frameworks/ is a separate GitHub project (github.com/michael-rowe/path-frameworks).
# Users install frameworks via Path: Add framework — they don't need this folder.
path-frameworks/

# --- Local reports ---
reports/
rclone_config/
